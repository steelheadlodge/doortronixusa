{
  "expo": {
    "name": "TunedTV",
    "slug": "TunedTV",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tunedtv",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.tunedtv.app",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tunedtv.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.585609408161-7clkl3840gq1j05k9pc2jl36mcumsi60"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "dc41ee5b-266b-4f94-9c02-cd1c6c7b79ee"
      }
    },
    "owner": "spcecwby"
  }
}
